# =============================================================
# Sentinel Frontend — .gitignore
# =============================================================

# -------------------------
# 환경 변수 / 민감 정보
# -------------------------
.env
.env.*
!.env.example
*.local

# -------------------------
# 빌드 산출물
# -------------------------
dist/
dist-ssr/
build/

# -------------------------
# 의존성
# -------------------------
node_modules/

# -------------------------
# 로그
# -------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------
# 테스트 / 커버리지
# -------------------------
coverage/
.nyc_output/

# -------------------------
# AI 도구 (민감 컨텍스트 포함 가능)
# -------------------------
.claude/

# -------------------------
# 에디터 / OS
# -------------------------
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -------------------------
# Vite / TypeScript 캐시
# -------------------------
*.tsbuildinfo
.vite/
