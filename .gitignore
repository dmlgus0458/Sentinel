# =============================================================
# Sentinel — Root .gitignore
# =============================================================

# -------------------------
# 환경 변수 / 민감 정보 (최우선)
# -------------------------
.env
.env.*
!.env.example          # example 파일은 커밋 허용
*.local

# -------------------------
# 인증서 / 키 파일
# -------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
*.der
id_rsa
id_ed25519

# -------------------------
# Go 백엔드 빌드 산출물
# -------------------------
__debug_bin
__debug_bin*
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
/backend/tmp/
/backend/vendor/
/backend/sentinel-backend

# -------------------------
# AI 도구 데이터 (민감 컨텍스트 포함 가능)
# -------------------------
.claude/
.agent/

# -------------------------
# OS / 에디터
# -------------------------
.DS_Store
Thumbs.db
*.suo
*.sln
*.sw?
.idea/
.vscode/
!.vscode/extensions.json

# -------------------------
# 개발용 임시 파일
# -------------------------
frontend/preview-*.html

# -------------------------
# 기타 로그
# -------------------------
*.log
logs/
